{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CockpitAgentOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "currentGoal",
    "nextAction",
    "proofNeeded",
    "parkingLot",
    "handoff",
    "assumptions",
    "blockers"
  ],
  "properties": {
    "currentGoal": {
      "type": "string",
      "minLength": 1
    },
    "nextAction": {
      "type": "string",
      "minLength": 1
    },
    "proofNeeded": {
      "type": "string",
      "minLength": 1
    },
    "parkingLot": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "handoff": {
      "type": ["string", "null"]
    },
    "assumptions": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
